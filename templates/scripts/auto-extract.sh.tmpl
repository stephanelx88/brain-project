#!/bin/bash
# Brain auto-extract — generated from templates/scripts/auto-extract.sh.tmpl by
# bin/install.sh. Edit the template, not this file (it gets overwritten).
#
# Two guards against the dual-instance Mac freeze (incident 2026-04-11):
#   1. flock singleton — never overlap two launchd runs
#   2. active-session check — skip the LLM-calling stages while Claude Code
#      *or Cursor Agent* is actively writing a transcript. Both are checked
#      because either can end up spawning a Claude process under the hood
#      (Cursor's brain MCP also calls `claude --print` for auto_extract).

set -euo pipefail

export PATH="{{HOME}}/.local/bin:{{HOME}}/.pyenv/shims:/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin"
export PYTHONPATH="{{PROJECT_DIR}}/src${PYTHONPATH:+:$PYTHONPATH}"
PYTHON="{{PYTHON}}"

LOG_DIR="{{HOME}}/.brain/logs"
mkdir -p "$LOG_DIR"
LOG="$LOG_DIR/auto-extract.log"
LOCKDIR="{{HOME}}/.brain/.extract.lock.d"

if ! mkdir "$LOCKDIR" 2>/dev/null; then
  if [[ -f "$LOCKDIR/pid" ]] && kill -0 "$(cat "$LOCKDIR/pid" 2>/dev/null)" 2>/dev/null; then
    echo "=== $(date -u +%Y-%m-%dT%H:%M:%SZ) SKIP: prior extract still running ===" >> "$LOG"
    exit 0
  fi
  rm -rf "$LOCKDIR"
  mkdir "$LOCKDIR"
fi
echo $$ > "$LOCKDIR/pid"
trap 'rm -rf "$LOCKDIR"' EXIT

# Idle-time guard: only the LLM-calling stages skip when a Claude Code OR
# Cursor agent session was actively typing in the last IDLE_THRESHOLD seconds.
# Pure-Python stages always run — they don't spawn `claude --print` so they
# can't trigger the dual-instance freeze, and we need them to keep the index
# fresh while you work.
IDLE_THRESHOLD=180
NEWEST_CLAUDE=$(find "{{HOME}}/.claude/projects" -name "*.jsonl" -type f -print0 2>/dev/null \
  | xargs -0 stat -f %m 2>/dev/null | sort -n | tail -1)
NEWEST_CURSOR=$(find "{{HOME}}/.cursor/projects" -path "*/agent-transcripts/*" -name "*.jsonl" -type f -print0 2>/dev/null \
  | xargs -0 stat -f %m 2>/dev/null | sort -n | tail -1)
NEWEST=0
for ts in "$NEWEST_CLAUDE" "$NEWEST_CURSOR"; do
  if [[ -n "$ts" && "$ts" -gt "$NEWEST" ]]; then NEWEST=$ts; fi
done
ACTIVE_SESSION=0
if (( NEWEST > 0 )) && (( $(date +%s) - NEWEST < IDLE_THRESHOLD )); then
  ACTIVE_SESSION=1
fi

{
  echo "=== $(date -u +%Y-%m-%dT%H:%M:%SZ) auto-extract run (active_session=$ACTIVE_SESSION) ==="
  # Always-safe stages (pure Python, no LLM subprocess):
  "$PYTHON" -m brain.harvest_session || echo "harvest exited $?"
  "$PYTHON" -m brain.ingest_notes     || echo "ingest_notes exited $?"
  "$PYTHON" -m brain.clean --execute  || echo "clean exited $?"

  # LLM-calling stages — skip while a Claude session is actively writing.
  if (( ACTIVE_SESSION == 0 )); then
    "$PYTHON" -m brain.auto_extract           || echo "auto_extract exited $?"
    "$PYTHON" -m brain.reconcile              || echo "reconcile exited $?"
    # Semantic dedupe — bounded LLM calls per run, ledger-skipped after.
    # Catches the same-idea-different-wording dupes that brain.reconcile
    # (slug-only) is blind to. Conservative thresholds per type; merges
    # below the auto bar become proposal files in timeline/ for review.
    "$PYTHON" -m brain.dedupe --apply --quiet || echo "dedupe exited $?"
  else
    echo "skip auto_extract+reconcile+dedupe: active session (last write $(($(date +%s) - NEWEST))s ago)"
  fi
  echo ""
} >> "$LOG" 2>&1

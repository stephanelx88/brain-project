#!/bin/bash
# Brain autoresearch tick — generated from
# templates/scripts/autoresearch-tick.sh.tmpl by bin/install.sh. Edit the
# template, not this file (it gets overwritten).
#
# Runs one autoresearch cycle (brain.autoresearch --cycles 1) on a
# launchd timer. Phase 0.5 of the brain roadmap: autoresearch used to
# require the user to run it manually; now it's autonomous.
#
# Guards (same shape as auto-extract.sh — cf. incident 2026-04-11):
#   1. flock singleton   — never overlap two ticks (cycles can run 5-10 min).
#   2. process-level     — skip if another `claude --print` is running.
#                          Autoresearch spawns its own `claude --print`;
#                          two in parallel is the freeze risk we avoid.
#   3. program.md exists — autoresearch hard-exits if missing; we skip
#                          early so the log doesn't fill with noise.

set -euo pipefail

export PATH="{{HOME}}/.local/bin:{{HOME}}/.pyenv/shims:/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin"
export PYTHONPATH="{{PROJECT_DIR}}/src${PYTHONPATH:+:$PYTHONPATH}"
PYTHON="{{PYTHON}}"

LOG_DIR="{{HOME}}/.brain/logs"
mkdir -p "$LOG_DIR"
LOG="$LOG_DIR/autoresearch.log"
LOCKDIR="{{HOME}}/.brain/.autoresearch.lock.d"

if ! mkdir "$LOCKDIR" 2>/dev/null; then
  if [[ -f "$LOCKDIR/pid" ]] && kill -0 "$(cat "$LOCKDIR/pid" 2>/dev/null)" 2>/dev/null; then
    echo "=== $(date -u +%Y-%m-%dT%H:%M:%SZ) SKIP: prior tick still running ===" >> "$LOG"
    exit 0
  fi
  rm -rf "$LOCKDIR"
  mkdir "$LOCKDIR"
fi
echo $$ > "$LOCKDIR/pid"
trap 'rm -rf "$LOCKDIR"' EXIT

if [[ ! -f "{{HOME}}/.brain/program.md" ]]; then
  echo "=== $(date -u +%Y-%m-%dT%H:%M:%SZ) SKIP: ~/.brain/program.md missing ===" >> "$LOG"
  exit 0
fi

if pgrep -f "claude --print" >/dev/null 2>&1; then
  echo "=== $(date -u +%Y-%m-%dT%H:%M:%SZ) SKIP: another claude --print is running ===" >> "$LOG"
  exit 0
fi

{
  echo "=== $(date -u +%Y-%m-%dT%H:%M:%SZ) autoresearch tick ==="
  "$PYTHON" -m brain.autoresearch --cycles 1 || echo "autoresearch exited $?"
  echo ""
} >> "$LOG" 2>&1

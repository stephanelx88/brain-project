#!/bin/bash
# Brain auto-extract — generated from templates/scripts/auto-extract.sh.tmpl by
# bin/install.sh. Edit the template, not this file (it gets overwritten).
#
# Two guards against the dual-instance Mac freeze (incident 2026-04-11):
#   1. flock singleton — never overlap two launchd runs
#   2. process-level check — skip LLM stages only when another `claude --print`
#      is *actually* running. Files in <vault>/raw/ are already proof of an
#      idle session (harvest gates on 60s idle), so we don't need an mtime
#      guard — the only real risk is two `claude --print` racing for the GPU.

set -euo pipefail

export PATH="{{HOME}}/.local/bin:{{HOME}}/.pyenv/shims:/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin"
export PYTHONPATH="{{PROJECT_DIR}}/src${PYTHONPATH:+:$PYTHONPATH}"
# Tell brain.config which vault to operate on (launchd doesn't read the
# user's shell rc, so without this it would default to ~/.brain).
export BRAIN_DIR="{{BRAIN_DIR}}"
# Source persisted brain config (BRAIN_USE_CLAIMS, BRAIN_STRICT_CLAIMS, ...).
# launchd doesn't read shell rc, so without this dual-write to
# fact_claims is silently disabled — see incident 2026-04-27.
[ -f "$BRAIN_DIR/.brain.conf" ] && . "$BRAIN_DIR/.brain.conf"
PYTHON="{{PYTHON}}"

LOG_DIR="{{BRAIN_DIR}}/logs"
mkdir -p "$LOG_DIR"
LOG="$LOG_DIR/auto-extract.log"
LOCKDIR="{{BRAIN_DIR}}/.extract.lock.d"

if ! mkdir "$LOCKDIR" 2>/dev/null; then
  if [[ -f "$LOCKDIR/pid" ]] && kill -0 "$(cat "$LOCKDIR/pid" 2>/dev/null)" 2>/dev/null; then
    echo "=== $(date -u +%Y-%m-%dT%H:%M:%SZ) SKIP: prior extract still running ===" >> "$LOG"
    exit 0
  fi
  rm -rf "$LOCKDIR"
  mkdir "$LOCKDIR"
fi
echo $$ > "$LOCKDIR/pid"
trap 'rm -rf "$LOCKDIR"' EXIT

# Resource-aware clearance gate.
# Level 1 (CPU<60%)             — pure-Python stages (no LLM)
# Level 2 (CPU<40% + idle 60s)  — LLM extract, note_extract, reconcile
# Level 3 (CPU<20% + idle 180s + AC) — dedupe (heavier LLM, longer per run)
#
# Process-level dual-instance guard: skip LLM stages while another
# `claude --print` is running to avoid the Mac GPU freeze (incident 2026-04-11).
LEVEL=$("$PYTHON" -m brain.resource_guard 2>/dev/null || echo 0)
ACTIVE_SESSION=0
if pgrep -f "claude --print" >/dev/null 2>&1; then
  ACTIVE_SESSION=1
fi

{
  echo "=== $(date -u +%Y-%m-%dT%H:%M:%SZ) auto-extract run (level=$LEVEL active_session=$ACTIVE_SESSION) ==="

  # Level 0 — always (harvest is pure I/O, no CPU spike)
  "$PYTHON" -m brain.harvest_session || echo "harvest exited $?"

  # Level 1 — pure Python, no LLM
  if (( LEVEL >= 1 )); then
    "$PYTHON" -m brain.ingest_notes    || echo "ingest_notes exited $?"
    "$PYTHON" -m brain.clean --execute || echo "clean exited $?"
  else
    echo "skip ingest_notes+clean: CPU too high (level=$LEVEL)"
  fi

  # Level 2 — LLM stages; also blocked while another claude --print runs
  if (( LEVEL >= 2 && ACTIVE_SESSION == 0 )); then
    "$PYTHON" -m brain.auto_extract  || echo "auto_extract exited $?"
    # Note extraction: turn user-typed vault notes into entity facts with
    # provenance, so deleting a note auto-retracts the fact (see
    # brain/note_extract.py + brain/ingest_notes.invalidate_facts_for_note).
    # Capped at MAX_NOTES_PER_RUN=30 inside the module so this never
    # dominates the launchd window.
    "$PYTHON" -m brain.note_extract  || echo "note_extract exited $?"
    "$PYTHON" -m brain.reconcile     || echo "reconcile exited $?"
  elif (( LEVEL < 2 )); then
    echo "skip auto_extract+note_extract+reconcile: level=$LEVEL (need 2)"
  else
    echo "skip auto_extract+note_extract+reconcile: another claude --print is running"
  fi

  # Level 3 — heavier LLM (dedupe); also blocked while another claude --print runs
  if (( LEVEL >= 3 && ACTIVE_SESSION == 0 )); then
    # Semantic dedupe — bounded LLM calls per run, ledger-skipped after.
    # Catches same-idea-different-wording dupes that brain.reconcile is blind to.
    "$PYTHON" -m brain.dedupe --apply --quiet || echo "dedupe exited $?"
  elif (( LEVEL < 3 )); then
    echo "skip dedupe: level=$LEVEL (need 3)"
  else
    echo "skip dedupe: another claude --print is running"
  fi

  echo ""
} >> "$LOG" 2>&1
